    rot90(squeeze(img_gp(:,nslcd+fasel*9-20+4,:))),rot90(squeeze(img_gp(:,nslcd+fasel*10-20+5,:))),rot90(squeeze(img_gp(:,nslcd+fasel*11-20+6,:)))]);

