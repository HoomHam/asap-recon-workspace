% axis image off
% colormap gray
% % caxis([-5 45])
% drawnow()

%%%% CS
% XFM = 1;				% Identity transform
% TVWeight = 0.02; 	% Weight for TV penalty
% xfmWeight = 0.01;	% Weight for Transform L1 penalty
% Itnlim = 500;		% Number of iterations

%%%% CS
XFM = 1;				% Identity transform
TVWeight = 0.02; 	% Weight for TV penalty
xfmWeight = 0.01;	% Weight for Transform L1 penalty
Itnlim = 500;		% Number of iterations

% initialize Parameters for reconstruction
param = init;
param.FT = FT; % image to k-space transform
param.XFM = XFM;
param.TV = TVOP3D;
param.data = data;
param.TVWeight =TVWeight;     % TV penalty
param.xfmWeight = xfmWeight;  % L1 wavelet penalty
param.Itnlim = Itnlim;

% scale w?
% tmp=zeros(N); tmp(end/2+1,end/2+1)=1; tmp=FT'*(w.*(FT*tmp)); w = w/max(abs(tmp(:)));

% im_dc = FT'*(data.*w);	% init with zf-w/dc (zero-fill with density compensation)
% figure(100), imshow(abs(im_dc),[]);drawnow;

res = XFM*im_dc;

% do iterations
tic
for n=1:3
    res = fnlCg(res,param);
    im_res = XFM'*res;
    % image = squeeze(abs(im_res(:,:,45)));
    figure(100+n), %imshow(image,[]), drawnow
    img_gp = abs(im_res);

    for jj=1:size(img_gp,1)
        tmp = squeeze(img_gp(jj,:,:));
        img_gp(jj,:,:) = rot90(tmp);
    end

    img_gp = img_gp/max(img_gp(:));

    %     for jj=1:size(img_gp,1)
    % tmp = squeeze(img_gp(jj,:,:));
    % img_gp(jj,:,:) = rot90(tmp);
    % end

    % Version 2
    nslcd = round(MS_recon_desired/2);
    fasel = 3;

    imagesc([fliplr(flipud(squeeze(img_gp(nslcd,:,:)))),rot90(squeeze(img_gp(:,nslcd+fasel-20,:))),rot90(squeeze(img_gp(:,nslcd+fasel*2-20+2,:))); ...
        rot90(squeeze(img_gp(:,nslcd+fasel*3-20+1,:))), rot90(squeeze(img_gp(:,nslcd+fasel*4-20+2,:))),rot90(squeeze(img_gp(:,nslcd+fasel*5-20+2,:))); ...
        rot90(squeeze(img_gp(:,nslcd+fasel*6-20+2,:))),rot90(squeeze(img_gp(:,nslcd+fasel*7-20+3,:))),rot90(squeeze(img_gp(:,nslcd+fasel*8-20+4,:))); ...
        rot90(squeeze(img_gp(:,nslcd+fasel*9-20+4,:))),rot90(squeeze(img_gp(:,nslcd+fasel*10-20+5,:))),rot90(squeeze(img_gp(:,nslcd+fasel*11-20+6,:)))]);


    % % Version 2
    % nslcd = round(MS_recon_desired/2);
    % fasel = 3;
    %
    % imagesc([fliplr(flipud(squeeze(img_gp(nslcd,:,:)))),rot90(squeeze(img_gp(:,:,nslcd+fasel-20))),rot90(squeeze(img_gp(:,:,nslcd+fasel*2-20+1))); ...
    %     rot90(squeeze(img_gp(:,:,nslcd+fasel*3-20+1))), rot90(squeeze(img_gp(:,:,nslcd+fasel*4-20+2))),rot90(squeeze(img_gp(:,:,nslcd+fasel*5-20+2))); ...
    %     rot90(squeeze(img_gp(:,:,nslcd+fasel*6-20+2))),rot90(squeeze(img_gp(:,:,nslcd+fasel*7-20+3))),rot90(squeeze(img_gp(:,:,nslcd+fasel*8-20+4))); ...
    %     rot90(squeeze(img_gp(:,:,nslcd+fasel*9-20+4))),rot90(squeeze(img_gp(:,:,nslcd+fasel*10-20+5))),rot90(squeeze(img_gp(:,:,nslcd+fasel*11-20+6)))]);


    % imagesc([fliplr(flipud(squeeze(img_gp(80,:,:)))),rot90(squeeze(img_gp(:,32+22,:))),rot90(squeeze(img_gp(:,38+22,:))); ...
    %      rot90(squeeze(img_gp(:,46+22,:))), rot90(squeeze(img_gp(:,54+22,:))),rot90(squeeze(img_gp(:,62+22,:))); ...
    %      rot90(squeeze(img_gp(:,70+22,:))),rot90(squeeze(img_gp(:,78+22,:))),rot90(squeeze(img_gp(:,86+22,:))); ...
    %      rot90(squeeze(img_gp(:,94+22,:))),rot90(squeeze(img_gp(:,102+22,:))),rot90(squeeze(img_gp(:,110+22,:)))]);

    % imagesc([
    %    rot90(squeeze(img_gp(:,:,22+80))),rot90(squeeze(img_gp(:,:,23+80))),rot90(squeeze(img_gp(:,:,24+80))),rot90(squeeze(img_gp(:,:,25+80))),rot90(squeeze(img_gp(:,:,26+80))),rot90(squeeze(img_gp(:,:,27+80))),rot90(squeeze(img_gp(:,:,28+80))),rot90(squeeze(img_gp(:,:,29+80))); ...
